<apex:page standardController="Tour_Expense__c" extensions="AddExp"> 
 <apex:form >
      <apex:pageBlock title="Expense Shared by?">
        <apex:pageBlockSection columns="1">
             <apex:pageBlockSectionItem >
               <apex:selectList value="{!banks}" multiselect="true" size="6" >
                    <apex:selectOptions value="{!getPeople1}"/>
                </apex:selectList>
            </apex:pageBlockSectionItem>
            </apex:pageBlockSection>
            <apex:pageBlockButtons location="bottom">
            <apex:commandButton value="Submit" action="{!Calculate}"/>
        </apex:pageBlockButtons>          
          </apex:pageBlock>
  </apex:form>
</apex:page>